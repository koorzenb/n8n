# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Timezone (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Halifax

# Your home address (used as origin for Google Maps travel time)
HOME_ADDRESS=your home address here

# Google Maps Distance Matrix API key
# Enable at: https://console.cloud.google.com/apis/library/distance-matrix-backend.googleapis.com
# Restrict the key to "Distance Matrix API" only for security
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Amazon session cookie (captured from browser Network tab — see setup guide)
# Refresh every ~2 weeks when it expires
ALEXA_COOKIE=your_amazon_cookie_string_here

# Name of your Alexa device (e.g. "Echo Dot" or "Living Room")
# Run: curl http://localhost:3001/devices  after startup to see available names
ALEXA_DEVICE_NAME=Echo

# Full name of the Alexa household profile to send reminders to (e.g. "Jane Smith")
# Leave blank to send to all users
ALEXA_PROFILE_NAME=your_full_name_here
